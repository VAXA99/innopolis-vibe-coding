PORT=8787
API_TOKEN=replace_with_strong_random_token

# Optional:
# If true, server returns deterministic mock data.
MOCK_MODE=true

# Live mode settings (used when MOCK_MODE=false)
REMOTE_SOURCE_URL=
REMOTE_SOURCE_TOKEN=
TOKEN_REFRESH_SKEW_SECONDS=120

# Placeholder OAuth credentials for future real integration.
HUAWEI_CLIENT_ID=
HUAWEI_CLIENT_SECRET=
HUAWEI_REDIRECT_URI=

# Supabase (опционально): дублирование регистраций в Postgres для Table Editor / SQL
# Project Settings → API: Project URL и service_role (только на сервере, не в iOS!)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
